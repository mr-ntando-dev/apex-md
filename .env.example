# ─────────────────────────────────────────
#  APEX-MD  ·  Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Bot Identity
BOT_NAME=APEX-MD
BOT_PREFIX=.
OWNER_NAME=YourName
OWNER_NUMBER=2348012345678   # full number, no +, no spaces

# Mode
PUBLIC_MODE=false            # true = anyone can use bot
AUTO_READ=true
AUTO_STATUS=true
AUTO_TYPING=true

# AI (required for AI commands)
AI_ENABLED=true
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o
GEMINI_API_KEY=              # optional, used as fallback

# Database (MongoDB — required for group settings persistence)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/apexmd

# External APIs
WEATHER_API_KEY=             # https://openweathermap.org/api
NEWS_API_KEY=                # https://newsapi.org

# Business
CRM_WEBHOOK_URL=             # optional

# Logging
LOG_LEVEL=info               # debug | info | warn | error
