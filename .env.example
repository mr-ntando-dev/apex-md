# ═══════════════════════════════════════════════════════════════
#  APEX-MD  ·  Environment Variables  ·  2026 Supreme Edition
#  Copy this file to .env and fill in the values.
#  "Queen Elisa ruled 2023. APEX-MD rules 2026."
# ═══════════════════════════════════════════════════════════════

# ── Bot Identity ───────────────────────────────────────────────
BOT_NAME=APEX-MD
BOT_PREFIX=.
OWNER_NAME=YourName
OWNER_NUMBER=2348012345678    # full number, no +, no spaces

# ── Mode ───────────────────────────────────────────────────────
PUBLIC_MODE=false             # true = anyone can use bot
AUTO_READ=true
AUTO_STATUS=true
AUTO_TYPING=true

# ── AI Engine (Triple Engine — add any 1 or all 3) ────────────
AI_ENABLED=true
AI_ROUTER=auto                # auto | openai | claude | gemini

# Option 1: OpenAI (GPT-4o + DALL-E 3 + Vision)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o

# Option 2: Anthropic Claude 3.5 Sonnet (best quality AI)
# Get key: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# Option 3: Google Gemini 2.0 Flash (fastest, free tier available)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── AI Voice (ElevenLabs) — .voice command ─────────────────────
# Get key: https://elevenlabs.io (free tier = 10,000 chars/month)
ELEVENLABS_API_KEY=
AI_VOICE_ID=EXAVITQu4vr4xnSDxMaL    # Bella (multilingual)

# ── AI Image Generation (Stability AI fallback) ───────────────
# Get key: https://platform.stability.ai/account/credits
STABILITY_API_KEY=

# ── Live Web Search (Perplexity Sonar Pro) — .search command ──
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# ── Database (MongoDB — recommended for persistence) ──────────
# Free tier: https://cloud.mongodb.com (M0 cluster)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/apexmd

# ── External APIs ─────────────────────────────────────────────
WEATHER_API_KEY=              # https://openweathermap.org/api (free tier)
NEWS_API_KEY=                 # https://newsapi.org (free tier)

# ── Guardian AI ───────────────────────────────────────────────
GUARDIAN_ENABLED=true         # AI-powered scam/raid/impersonation protection
GUARDIAN_SCAM_KICK=true       # auto-kick confirmed scammers (score >= 9)

# ── Business ──────────────────────────────────────────────────
CRM_WEBHOOK_URL=              # optional CRM webhook

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info                # debug | info | warn | error

# ── Anime Reactions ───────────────────────────────────────────
# Get free key: https://tenor.com/developer (create app, copy API key)
TENOR_API_KEY=

# ── Song Recognition (.shazam) ────────────────────────────────
# Get free key: https://audd.io (sign up, free tier: 100 recognitions/month)
AUDD_API_KEY=

# ── URL Security Scanning (.virus) ───────────────────────────
# Get free key: https://urlscan.io/user/signup
URLSCAN_API_KEY=

# ── Language ──────────────────────────────────────────────────
# Default bot language: en | pt | es | fr | sw | zu | ha
DEFAULT_LANG=en
